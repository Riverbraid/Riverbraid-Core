#!/usr/bin/env node
const { execSync } = require('child_process');
const path = require('path');

const command = process.argv[2];

if (command === 'boot') {
    console.log("💎 RIVERBRAID BOOT SEQUENCE INITIATED");
    try {
        execSync('node /workspaces/Riverbraid-Core/bin/enforcer.cjs', { stdio: 'inherit' });
        execSync('node /workspaces/Riverbraid-Core/bin/recovery/sentinel.cjs', { stdio: 'inherit' });
        console.log("\n✨ SYSTEM STATUS: ABSOLUTE COMPLETION. ALL GATES OPEN.");
    } catch (e) {
        console.error("\n❌ BOOT ABORTED: Sovereignty Breach Detected.");
        process.exit(1);
    }
} else if (command === 'status') {
    execSync('node /workspaces/Riverbraid-Interface-Gold/bin/observe', { stdio: 'inherit' });
} else {
    console.log("Usage: braid [boot|status]");
}
