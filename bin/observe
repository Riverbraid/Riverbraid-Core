#!/usr/bin/env node
const path = require('path');
const fs = require('fs');

// Path resolution to ensure residency
const signalPath = path.join(process.cwd(), 'src/connectors/health-signal.js');

if (!fs.existsSync(signalPath)) {
    console.error(`🚨 CRITICAL: Health signal module not found at ${signalPath}`);
    process.exit(1);
}

const { getPublicSignal } = require(signalPath);
const { logSignal } = require('@riverbraid/core/ledger');

console.log("🔭 RIVERBRAID UNIVERSAL OBSERVER INITIATED...");

try {
    const signal = getPublicSignal();
    logSignal(parseFloat(signal.entropy_signal), signal.status);

    console.log("\n--- CURRENT SYSTEM STATE ---");
    console.table({
        "Identity": "Node-28c98bd1",
        "Entropy": signal.entropy_signal + " bits/sym",
        "Braid State": signal.braid_state,
        "Mechanical": "VERIFIED",
        "Truth": signal.relational_truth
    });

    console.log("\n✅ Signal recorded to Historical Ledger.");
} catch (e) {
    console.error("❌ OBSERVATION FAILED: " + e.message);
    process.exit(1);
}
